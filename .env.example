# Optional cross-device sync. Leave blank to run the app local-only (no login).
#
# To enable:
#   1. Create a free project at https://supabase.com
#   2. SQL Editor → run supabase/schema.sql
#   3. Project Settings → API → copy the values below into a .env.local file
#
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
